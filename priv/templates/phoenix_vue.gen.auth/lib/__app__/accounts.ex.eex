defmodule <%= @base_string %>.Accounts do
  @moduledoc """
  The global identity context: `User`, `PasswordCredential`, and `Session`.
  Lives ABOVE the tenant boundary — no function in this module accepts an
  `organization_id` or filters by one.

  Tenant-scoped membership lives in `<%= @base_string %>.Organizations`.
  """

  require Logger

  import Ecto.Query

  alias <%= @base_string %>.Accounts.{
    PasswordCredential,
    PasswordCredentialQueries,
    Session,
    SessionQueries,
    User,
    UserQueries
  }

  alias <%= @base_string %>.Auth.{Config, PasswordHasher, Token}
  alias <%= @repo_string %>

  @type sign_in_result ::
          {:ok, User.t()}
          | {:error, :invalid_credentials}
          | {:error, :locked, DateTime.t()}
          | {:error, :email_not_verified, User.t()}

  # ----- Users -----

  def get_user(id), do: Repo.get(User, id)

  def get_user_by_email(email) do
    User |> UserQueries.by_email(email) |> Repo.one()
  end

  def get_user_by_email_with_password(email) do
    User
    |> UserQueries.by_email(email)
    |> UserQueries.with_password_credential()
    |> Repo.one()
  end

  @doc """
  Registers a brand-new password user. Returns `{:ok, %{user, credential,
  verification_token}}` with the **raw** verification token, or
  `{:error, %Ecto.Changeset{}}`.

  Duplicate-email handling: `User.registration_changeset/2` declares
  `unique_constraint(:primary_email)`, so a duplicate insert returns
  `{:error, changeset}` with a `:primary_email` error. The registration
  controller catches that case and returns the enumeration-safe response
  (anti-enum: callers cannot tell whether the email is taken or new).
  """
  def register_user(attrs) do
    {raw_token, hash} = Token.generate()
    expires_at = ttl_from_now(:email_verification_token_ttl_minutes, :minute)

    Ecto.Multi.new()
    |> Ecto.Multi.insert(:user, User.registration_changeset(%User{}, attrs))
    |> Ecto.Multi.update(:user_with_token, fn %{user: user} ->
      User.put_email_verification_token(user, hash, expires_at)
    end)
    |> Ecto.Multi.insert(:credential, fn %{user: user} ->
      PasswordCredential.registration_changeset(%PasswordCredential{}, %{
        user_id: user.id,
        password: Map.get(attrs, :password) || Map.get(attrs, "password")
      })
    end)
    |> Repo.transaction()
    |> case do
      {:ok, %{user_with_token: user, credential: credential}} ->
        {:ok, %{user: user, credential: credential, verification_token: raw_token}}

      {:error, _step, changeset, _} ->
        {:error, changeset}
    end
  end

  @doc "Re-issues a fresh email-verification token. `{:ok, raw_token}` or `{:error, reason}`."
  def reissue_email_verification(%User{primary_email_verified: true}),
    do: {:error, :already_verified}

  def reissue_email_verification(%User{} = user) do
    {raw_token, hash} = Token.generate()
    expires_at = ttl_from_now(:email_verification_token_ttl_minutes, :minute)

    case user |> User.put_email_verification_token(hash, expires_at) |> Repo.update() do
      {:ok, _user} -> {:ok, raw_token}
      {:error, changeset} -> {:error, changeset}
    end
  end

  @doc "Verifies a presented email-verification token."
  def verify_email(raw_token) when is_binary(raw_token) do
    hash = Token.hash(raw_token)

    Ecto.Multi.new()
    |> Ecto.Multi.one(:user, UserQueries.by_verification_token_hash(User, hash))
    |> Ecto.Multi.run(:check, fn _repo, %{user: user} ->
      cond do
        is_nil(user) -> {:error, :invalid_token}
        expired?(user.email_verification_expires_at) -> {:error, :expired}
        true -> {:ok, user}
      end
    end)
    |> Ecto.Multi.update(:confirmed_user, fn %{check: user} ->
      User.confirm_email_changeset(user)
    end)
    |> Repo.transaction()
    |> case do
      {:ok, %{confirmed_user: user}} -> {:ok, user}
      {:error, :check, reason, _} -> {:error, reason}
      {:error, _step, changeset, _} -> {:error, changeset}
    end
  end

  # ----- Authentication -----

  @doc """
  Verifies email + password. Returns one of `{:ok, user}`,
  `{:error, :invalid_credentials}`, `{:error, :locked, locked_until}`, or
  `{:error, :email_not_verified, user}`. Always runs Argon2 verify (or
  `no_user_verify/0` on miss) so timing cannot leak email existence.
  """
  @spec authenticate(String.t(), String.t()) :: sign_in_result()
  def authenticate(email, password) when is_binary(email) and is_binary(password) do
    user = get_user_by_email_with_password(email)

    cond do
      is_nil(user) or is_nil(user.password_credential) ->
        PasswordHasher.no_user_verify()
        Logger.warning("auth.rejected", reason: :no_such_user_or_credential)
        {:error, :invalid_credentials}

      user.status != "active" ->
        PasswordHasher.no_user_verify()
        Logger.warning("auth.rejected", reason: :user_not_active, user_id: user.id)
        {:error, :invalid_credentials}

      locked?(user.password_credential) ->
        Logger.warning("auth.rejected", reason: :credential_locked, user_id: user.id)
        {:error, :locked, user.password_credential.locked_until}

      PasswordHasher.verify(password, user.password_credential.password_hash) ->
        on_successful_authentication(user, password)

      true ->
        record_failure(user.password_credential)
        Logger.warning("auth.rejected", reason: :wrong_password, user_id: user.id)
        {:error, :invalid_credentials}
    end
  end

  defp locked?(%PasswordCredential{locked_until: nil}), do: false

  defp locked?(%PasswordCredential{locked_until: locked_until}) do
    DateTime.compare(locked_until, DateTime.utc_now()) == :gt
  end

  defp on_successful_authentication(user, password) do
    cleared = clear_failures(user.password_credential)

    cleared =
      if PasswordHasher.needs_rehash?(cleared.password_hash) do
        cleared |> PasswordCredential.rehash_changeset(password) |> Repo.update!()
      else
        cleared
      end

    user = %{user | password_credential: cleared} |> touch_last_login()

    if user.primary_email_verified do
      {:ok, user}
    else
      Logger.warning("auth.rejected", reason: :email_not_verified, user_id: user.id)
      {:error, :email_not_verified, user}
    end
  end

  defp clear_failures(credential) do
    credential |> PasswordCredential.clear_failures() |> Repo.update!()
  end

  defp record_failure(credential) do
    credential
    |> PasswordCredential.record_failure(
      Config.failed_signin_threshold(),
      Config.failed_signin_lockout_minutes()
    )
    |> Repo.update!()
  end

  defp touch_last_login(user) do
    user |> Ecto.Changeset.change(%{last_login_at: now()}) |> Repo.update!()
  end

  # ----- Password reset -----

  @doc """
  Issues a fresh password-reset token for a known User. Used by
  `DeliverWorker` so the raw token never lives in Oban job args.
  """
  def issue_password_reset_for_user(%User{} = user) do
    user = Repo.preload(user, :password_credential)

    case user.password_credential do
      %PasswordCredential{} = credential ->
        {raw_token, hash} = Token.generate()
        expires_at = ttl_from_now(:password_reset_token_ttl_minutes, :minute)

        credential
        |> PasswordCredential.put_reset_token(hash, expires_at)
        |> Repo.update!()

        {:ok, raw_token}

      nil ->
        {:error, :no_password_credential}
    end
  end

  @doc """
  Initiates a password reset. Enumeration-safe: returns `:ok` regardless
  of whether the email exists. Returns `{:ok, %{user, reset_token}}` to
  the caller when the email matches, but the controller ignores the token
  (the DeliverWorker re-issues a fresh token via
  `issue_password_reset_for_user/1` before delivering the email).
  """
  def start_password_reset(email) do
    case get_user_by_email_with_password(email) do
      %User{password_credential: %PasswordCredential{} = credential} = user ->
        {raw_token, hash} = Token.generate()
        expires_at = ttl_from_now(:password_reset_token_ttl_minutes, :minute)

        credential
        |> PasswordCredential.put_reset_token(hash, expires_at)
        |> Repo.update!()

        {:ok, %{user: user, reset_token: raw_token}}

      _ ->
        :ok
    end
  end

  @doc "Consumes a reset token and sets a new password. Revokes all sessions."
  def complete_password_reset(raw_token, new_password) when is_binary(raw_token) do
    hash = Token.hash(raw_token)

    Ecto.Multi.new()
    |> Ecto.Multi.one(
      :credential,
      PasswordCredentialQueries.by_reset_token_hash(PasswordCredential, hash)
    )
    |> Ecto.Multi.run(:check, fn _repo, %{credential: credential} ->
      cond do
        is_nil(credential) -> {:error, :invalid_token}
        expired?(credential.password_reset_expires_at) -> {:error, :expired}
        true -> {:ok, credential}
      end
    end)
    |> Ecto.Multi.update(:updated, fn %{check: credential} ->
      PasswordCredential.password_change_changeset(credential, %{password: new_password})
    end)
    |> Ecto.Multi.delete_all(:revoke_sessions, fn %{check: credential} ->
      SessionQueries.for_user(Session, credential.user_id)
    end)
    |> Repo.transaction()
    |> case do
      {:ok, %{updated: credential}} -> {:ok, credential}
      {:error, :check, reason, _} -> {:error, reason}
      {:error, :updated, changeset, _} -> {:error, changeset}
      {:error, _step, reason, _} -> {:error, reason}
    end
  end

  @doc """
  Authenticated password change. Verifies the current password, validates
  the new one, deletes all of the user's sessions EXCEPT `keep_session_id`,
  and rotates that kept session's token (session-fixation defense).

  Returns `{:ok, %{credential, session_token}}` on success — the controller
  MUST set the new cookie with `session_token`.
  """
  def change_password(%User{} = user, current_password, new_password, keep_session_id) do
    case Repo.preload(user, :password_credential) do
      %{password_credential: nil} ->
        {:error, :no_password_credential}

      %{password_credential: credential} ->
        if PasswordHasher.verify(current_password, credential.password_hash) do
          do_change_password(credential, new_password, keep_session_id)
        else
          PasswordHasher.no_user_verify()
          {:error, :invalid_current_password}
        end
    end
  end

  defp do_change_password(credential, new_password, keep_session_id) do
    {raw_token, token_hash} = Token.generate()
    now = now()
    expires_at = DateTime.add(now, Config.session_max_age_seconds(), :second) |> DateTime.truncate(:second)

    Ecto.Multi.new()
    |> Ecto.Multi.update(
      :credential,
      PasswordCredential.password_change_changeset(credential, %{password: new_password})
    )
    |> Ecto.Multi.delete_all(:revoke_others, fn _ ->
      from s in Session, where: s.user_id == ^credential.user_id and s.id != ^keep_session_id
    end)
    |> Ecto.Multi.update(:rotated_session, fn _ ->
      kept = Repo.get!(Session, keep_session_id)
      Session.rotate_token_changeset(kept, token_hash, now, expires_at)
    end)
    |> Repo.transaction()
    |> case do
      {:ok, %{credential: credential}} ->
        {:ok, %{credential: credential, session_token: raw_token}}

      {:error, _step, changeset, _} ->
        {:error, changeset}
    end
  end

  # ----- Sessions -----

  @doc """
  Creates a Session for an authenticated user given a pre-fetched
  membership list. Picks the initial Member (head of the list, since the
  caller orders by `last_active_at desc nulls last`); auto-selects when
  exactly one membership exists, otherwise leaves `current_member_id: nil`
  so the SPA prompts the user to onboard or pick.
  """
  def create_session_for_authenticated_user(%User{} = user, request_meta, memberships)
      when is_list(memberships) do
    current_member_id = pick_initial_member(memberships)

    case create_session(user, current_member_id, request_meta) do
      {:ok, %{session: session, raw_token: raw_token}} ->
        current_member = Enum.find(memberships, &(&1.id == current_member_id))

        {:ok,
         %{
           session: session,
           raw_token: raw_token,
           current_member_id: current_member_id,
           current_member: current_member,
           memberships: memberships
         }}

      {:error, changeset} ->
        {:error, changeset}
    end
  end

  defp pick_initial_member([]), do: nil
  defp pick_initial_member([single]), do: single.id
  defp pick_initial_member([%{last_active_at: %DateTime{}} = head | _]), do: head.id
  defp pick_initial_member([_ | _]), do: nil

  @doc "Creates a Session for the given User. Returns `{:ok, %{session, raw_token}}`."
  def create_session(%User{} = user, current_member_id, request_meta) do
    {raw_token, hash} = Token.generate()
    now = now()
    expires_at = DateTime.add(now, Config.session_max_age_seconds(), :second) |> DateTime.truncate(:second)

    attrs = %{
      user_id: user.id,
      current_member_id: current_member_id,
      token_hash: hash,
      ip_address: Map.get(request_meta, :ip_address),
      user_agent: Map.get(request_meta, :user_agent),
      last_used_at: now,
      expires_at: expires_at
    }

    case %Session{} |> Session.changeset(attrs) |> Repo.insert() do
      {:ok, session} -> {:ok, %{session: session, raw_token: raw_token}}
      {:error, changeset} -> {:error, changeset}
    end
  end

  @doc """
  Looks up an active Session by the cookie's raw token. Returns the
  Session struct with `:user` preloaded, or `nil` for any failure.
  """
  def fetch_session_by_token(raw_token) when is_binary(raw_token) do
    hash = Token.hash(raw_token)

    query =
      from s in Session,
        join: u in assoc(s, :user),
        where:
          s.token_hash == ^hash and
            is_nil(s.revoked_at) and
            s.expires_at > ^DateTime.utc_now() and
            u.status == "active",
        preload: [user: u]

    Repo.one(query)
  end

  def fetch_session_by_token(_), do: nil

  @doc "Bumps `last_used_at`/`expires_at` if the throttle window has elapsed."
  def maybe_touch_session(%Session{} = session) do
    throttle = Config.session_last_used_throttle_seconds()
    age = DateTime.diff(now(), session.last_used_at, :second)

    if age >= throttle do
      now = now()
      expires_at = DateTime.add(now, Config.session_max_age_seconds(), :second) |> DateTime.truncate(:second)

      session |> Session.touch_changeset(now, expires_at) |> Repo.update!()
    else
      session
    end
  end

  def update_session_member!(%Session{} = session, member_id) do
    session |> Session.update_member_changeset(member_id) |> Repo.update!()
  end

  def revoke_session(%Session{} = session), do: Repo.delete(session)

  def revoke_session_by_id_for_user(id, user_id) do
    Session
    |> SessionQueries.by_id_for_user(id, user_id)
    |> Repo.one()
    |> case do
      nil -> {:error, :not_found}
      session -> Repo.delete(session)
    end
  end

  @doc "Deletes every Session row owned by the given user."
  def revoke_all_sessions_for_user(user_id) do
    {count, deleted} =
      Session
      |> SessionQueries.for_user(user_id)
      |> Ecto.Query.select([s], s.id)
      |> Repo.delete_all()

    {:ok, %{count: count, ids: deleted}}
  end

  def list_sessions_for_user(user_id) do
    Session
    |> SessionQueries.for_user(user_id)
    |> SessionQueries.active()
    |> order_by([s], desc: s.last_used_at)
    |> Repo.all()
  end

  # ----- Helpers -----

  defp ttl_from_now(:email_verification_token_ttl_minutes, unit) do
    Config.email_verification_token_ttl_minutes()
    |> tick_from_now(unit)
  end

  defp ttl_from_now(:password_reset_token_ttl_minutes, unit) do
    Config.password_reset_token_ttl_minutes()
    |> tick_from_now(unit)
  end

  defp tick_from_now(amount, unit) do
    DateTime.utc_now() |> DateTime.add(amount, unit) |> DateTime.truncate(:second)
  end

  defp expired?(nil), do: true
  defp expired?(%DateTime{} = at), do: DateTime.compare(at, DateTime.utc_now()) != :gt

  defp now, do: DateTime.utc_now() |> DateTime.truncate(:second)
end
