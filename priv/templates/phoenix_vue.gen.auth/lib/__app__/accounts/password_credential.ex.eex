defmodule <%= @base_string %>.Accounts.PasswordCredential do
  @moduledoc """
  Argon2id-hashed password and associated state for a `User`. Kept separate
  from the user record so password-specific concerns (hash parameters, reset
  token state, lockout) don't leak into the identity model.
  """

  use Ecto.Schema
  import Ecto.Changeset

  alias <%= @base_string %>.Accounts.User
  alias <%= @base_string %>.Auth.{PasswordHasher, PasswordPolicy}

  @primary_key {:id, :binary_id, autogenerate: true}
  @foreign_key_type :binary_id
  @timestamps_opts [type: :utc_datetime]

  schema "password_credentials" do
    belongs_to :user, User

    field :password_hash, :string
    field :hash_algorithm, :string, default: "argon2id"
    field :password_changed_at, :utc_datetime

    field :password_reset_token_hash, :binary
    field :password_reset_expires_at, :utc_datetime

    field :failed_attempts, :integer, default: 0
    field :locked_until, :utc_datetime

    # Virtual fields used by changesets only.
    field :password, :string, virtual: true, redact: true

    timestamps()
  end

  @doc "Changeset for setting an initial password during registration."
  def registration_changeset(credential, attrs) do
    credential
    |> cast(attrs, [:user_id, :password])
    |> validate_required([:user_id, :password])
    |> validate_password()
    |> put_password_hash()
    |> put_change(:hash_algorithm, "argon2id")
    |> put_change(:password_changed_at, now())
  end

  @doc "Changeset for an authenticated password change."
  def password_change_changeset(credential, attrs) do
    credential
    |> cast(attrs, [:password])
    |> validate_required([:password])
    |> validate_password()
    |> put_password_hash()
    |> put_change(:hash_algorithm, "argon2id")
    |> put_change(:password_changed_at, now())
    |> put_change(:failed_attempts, 0)
    |> put_change(:locked_until, nil)
    |> put_change(:password_reset_token_hash, nil)
    |> put_change(:password_reset_expires_at, nil)
  end

  @doc "Stores a new reset token hash and expiry."
  def put_reset_token(credential, hash, expires_at) do
    change(credential, %{
      password_reset_token_hash: hash,
      password_reset_expires_at: expires_at
    })
  end

  @doc "Records a failed sign-in. Locks the credential once the threshold trips."
  def record_failure(credential, threshold, lockout_minutes) do
    next_count = credential.failed_attempts + 1

    attrs =
      if next_count >= threshold do
        %{
          failed_attempts: next_count,
          locked_until:
            DateTime.utc_now()
            |> DateTime.add(lockout_minutes * 60, :second)
            |> DateTime.truncate(:second)
        }
      else
        %{failed_attempts: next_count}
      end

    change(credential, attrs)
  end

  @doc "Clears failure state and lockout."
  def clear_failures(credential) do
    change(credential, %{failed_attempts: 0, locked_until: nil})
  end

  @doc "Re-hashes the existing password with current Argon2 parameters."
  def rehash_changeset(credential, raw_password) do
    change(credential, %{
      password_hash: PasswordHasher.hash(raw_password),
      hash_algorithm: "argon2id"
    })
  end

  # --- private ---

  defp validate_password(changeset) do
    case get_change(changeset, :password) do
      nil ->
        changeset

      password ->
        case PasswordPolicy.validate(password) do
          :ok -> changeset
          {:error, :too_short} -> add_error(changeset, :password, "is too short", code: "too_short")
          {:error, :too_long} -> add_error(changeset, :password, "is too long", code: "too_long")
          {:error, :common} -> add_error(changeset, :password, "is too common", code: "weak_password")
        end
    end
  end

  defp put_password_hash(%Ecto.Changeset{valid?: true, changes: %{password: password}} = changeset) do
    changeset
    |> put_change(:password_hash, PasswordHasher.hash(password))
    |> delete_change(:password)
  end

  defp put_password_hash(changeset), do: changeset

  defp now, do: DateTime.utc_now() |> DateTime.truncate(:second)
end
