defmodule <%= @base_string %>.Auth.PasswordPolicy do
  @moduledoc """
  Password policy enforcement. The min/max length come from `Config`; the
  common-passwords blocklist is loaded at compile time from
  `priv/auth/common_passwords.txt` and baked into the module bytecode as a
  `MapSet` — there is no runtime file IO and no lazy-init race.
  Recompilation is triggered automatically when the blocklist file
  changes.

  Length validation counts GRAPHEMES, not bytes — an 8-character emoji
  passphrase shouldn't be rejected by `min: 8`.
  """

  alias <%= @base_string %>.Auth.Config

  @blocklist_path "priv/auth/common_passwords.txt"
  @external_resource @blocklist_path

  @blocklist (if File.exists?(@blocklist_path) do
                @blocklist_path
                |> File.read!()
                |> String.split("\n", trim: true)
                |> Stream.map(&String.trim/1)
                |> Stream.reject(&(&1 == ""))
                |> Stream.map(&String.downcase/1)
                |> MapSet.new()
              else
                MapSet.new()
              end)

  @doc """
  Returns `:ok` or `{:error, :too_short | :too_long | :common}`.
  """
  def validate(password) when is_binary(password) do
    length = String.length(password)

    cond do
      length < Config.password_min_length() -> {:error, :too_short}
      length > Config.password_max_length() -> {:error, :too_long}
      common?(password) -> {:error, :common}
      true -> :ok
    end
  end

  def validate(_), do: {:error, :too_short}

  @doc "Returns true if `password` is in the bundled blocklist."
  def common?(password) when is_binary(password) do
    MapSet.member?(@blocklist, String.downcase(password))
  end

  def common?(_), do: false

  @doc false
  def blocklist_size, do: MapSet.size(@blocklist)
end
