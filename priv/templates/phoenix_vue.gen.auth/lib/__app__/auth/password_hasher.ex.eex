defmodule <%= @base_string %>.Auth.PasswordHasher do
  @moduledoc """
  Argon2id wrapper. Centralizes calls so swapping algorithms in the future
  is a one-module change.
  """

  @doc "Hashes a raw password with the current Argon2 parameters."
  def hash(raw_password) when is_binary(raw_password) do
    Argon2.hash_pwd_salt(raw_password)
  end

  @doc "Verifies a raw password against a stored hash."
  def verify(raw_password, stored_hash) when is_binary(raw_password) and is_binary(stored_hash) do
    Argon2.verify_pass(raw_password, stored_hash)
  end

  def verify(_, _), do: false

  @doc """
  Performs a constant-time dummy verification. Call this on the
  missing-user branch of sign-in so wall-clock timing doesn't leak email
  existence.
  """
  def no_user_verify do
    Argon2.no_user_verify()
  end

  @doc """
  Returns true if the stored hash's embedded parameters are weaker than
  the currently configured parameters. The caller should rehash on next
  successful sign-in. Argon2's PHC hash carries `m=` as linear KiB; our
  app config (`config :argon2_elixir, :m_cost, N`) is the log2 exponent,
  so we convert before comparing.
  """
  def needs_rehash?(stored_hash) when is_binary(stored_hash) do
    cfg_t = Application.get_env(:argon2_elixir, :t_cost, 3)
    cfg_m_exp = Application.get_env(:argon2_elixir, :m_cost, 16)
    cfg_p = Application.get_env(:argon2_elixir, :parallelism, 4)
    cfg_m_kib = Bitwise.bsl(1, cfg_m_exp)

    segments = String.split(stored_hash, "$", trim: true)

    with params when is_binary(params) <-
           Enum.find(segments, &(is_binary(&1) and String.contains?(&1, "m="))),
         %{"m" => m, "t" => t, "p" => p} <- parse_params(params) do
      String.to_integer(t) < cfg_t or
        String.to_integer(m) < cfg_m_kib or
        String.to_integer(p) < cfg_p
    else
      _ -> false
    end
  end

  defp parse_params(params) do
    params
    |> String.split(",")
    |> Enum.reduce(%{}, fn pair, acc ->
      case String.split(pair, "=", parts: 2) do
        [k, v] -> Map.put(acc, k, v)
        _ -> acc
      end
    end)
  end
end
