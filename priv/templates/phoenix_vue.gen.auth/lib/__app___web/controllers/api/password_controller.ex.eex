defmodule <%= @web_string %>.Api.PasswordController do
  use <%= @web_string %>, :controller

  alias <%= @base_string %>.Accounts
  alias <%= @base_string %>.Auth.Mailer.DeliverWorker
  alias <%= @web_string %>.Plugs.SessionCookie

  action_fallback <%= @web_string %>.Api.FallbackController

  # POST /api/me/password-reset — request a reset link. Enumeration-safe.
  def request_reset(conn, %{"email" => email}) when is_binary(email) do
    case Accounts.get_user_by_email(email) do
      nil ->
        send_resp(conn, :no_content, "")

      user ->
        %{"kind" => "password_reset", "user_id" => user.id}
        |> DeliverWorker.new()
        |> Oban.insert()

        send_resp(conn, :no_content, "")
    end
  end

  def request_reset(conn, _), do: send_resp(conn, :no_content, "")

  # POST /api/me/password-reset/confirm — set a new password via reset token.
  def confirm_reset(conn, %{"token" => token, "password" => new_password})
      when is_binary(token) and is_binary(new_password) do
    with {:ok, _credential} <- Accounts.complete_password_reset(token, new_password) do
      send_resp(conn, :no_content, "")
    end
  end

  def confirm_reset(_conn, _params), do: {:error, :invalid_token}

  # POST /api/me/change-password — authenticated password change.
  def change(conn, %{"current_password" => current, "new_password" => new})
      when is_binary(current) and is_binary(new) do
    user = conn.assigns.current_user
    session = conn.assigns.current_session

    case Accounts.change_password(user, current, new, session.id) do
      {:ok, %{session_token: raw_token}} ->
        conn
        |> SessionCookie.put(raw_token)
        |> send_resp(:no_content, "")

      {:error, _} = err ->
        err
    end
  end

  def change(_conn, _params), do: {:error, :unprocessable_entity}
end
