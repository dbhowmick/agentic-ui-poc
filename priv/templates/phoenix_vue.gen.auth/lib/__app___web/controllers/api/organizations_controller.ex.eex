defmodule <%= @web_string %>.Api.OrganizationsController do
  use <%= @web_string %>, :controller

  alias <%= @base_string %>.Organizations

  action_fallback <%= @web_string %>.Api.FallbackController

  # POST /api/organizations — create a new org with the caller as owner.
  # Also updates the caller's session to make the new org current.
  def create(conn, %{"name" => name} = params) when is_binary(name) do
    user = conn.assigns.current_user
    session = conn.assigns.current_session

    attrs = %{name: name, display_name: Map.get(params, "display_name")}

    case Organizations.create_organization_for_user(user, session, attrs) do
      {:ok, %{organization: org, member: member}} ->
        conn
        |> put_status(:created)
        |> json(%{
          organization: organization_json(org),
          member: member_json(%{member | organization: org})
        })

      {:error, changeset} ->
        {:error, changeset}
    end
  end

  def create(_conn, _params), do: {:error, :unprocessable_entity}

  defp organization_json(org) do
    %{
      id: org.id,
      name: org.name,
      slug: org.slug,
      status: org.status,
      inserted_at: org.inserted_at
    }
  end

  defp member_json(member) do
    %{
      id: member.id,
      organization_id: member.organization_id,
      user_id: member.user_id,
      email: member.email,
      display_name: member.display_name,
      role: member.role,
      status: member.status,
      joined_at: member.joined_at,
      last_active_at: member.last_active_at,
      organization: organization_json(member.organization)
    }
  end
end
