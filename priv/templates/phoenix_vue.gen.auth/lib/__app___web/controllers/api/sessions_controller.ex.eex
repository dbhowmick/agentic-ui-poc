defmodule <%= @web_string %>.Api.SessionsController do
  use <%= @web_string %>, :controller

  alias <%= @base_string %>.{Accounts, Organizations}
  alias <%= @web_string %>.Plugs.{RequestMeta, SessionCookie}

  action_fallback <%= @web_string %>.Api.FallbackController

  # POST /api/sessions — sign in.
  def create(conn, %{"email" => email, "password" => password}) do
    with {:ok, user} <- Accounts.authenticate(email, password) do
      meta = %{ip_address: RequestMeta.client_ip(conn), user_agent: RequestMeta.user_agent(conn)}
      memberships = Organizations.list_memberships_for_user(user.id)

      case Accounts.create_session_for_authenticated_user(user, meta, memberships) do
        {:ok, %{raw_token: raw_token, current_member: current_member}} ->
          conn
          |> SessionCookie.put(raw_token)
          |> put_status(:created)
          |> json(%{
            me: render_me(user, current_member, memberships)
          })

        {:error, changeset} ->
          {:error, changeset}
      end
    end
  end

  def create(_conn, _params), do: {:error, :invalid_credentials}

  # DELETE /api/sessions/current — logout current session.
  def delete_current(conn, _params) do
    session = conn.assigns.current_session
    {:ok, _} = Accounts.revoke_session(session)

    conn
    |> SessionCookie.delete()
    |> send_resp(:no_content, "")
  end

  # POST /api/sessions/revoke-all — logout everywhere.
  def revoke_all(conn, _params) do
    user = conn.assigns.current_user
    {:ok, _} = Accounts.revoke_all_sessions_for_user(user.id)

    conn
    |> SessionCookie.delete()
    |> send_resp(:no_content, "")
  end

  # POST /api/me/switch-organization — change the session's current org.
  def switch_organization(conn, %{"organization_id" => organization_id}) do
    user = conn.assigns.current_user
    session = conn.assigns.current_session

    with {:ok, member} <- Organizations.verify_member_by_organization(user, organization_id) do
      _ = Accounts.update_session_member!(session, member.id)
      _ = Organizations.touch_member_active(member)
      memberships = Organizations.list_memberships_for_user(user.id)

      json(conn, %{me: render_me(user, member, memberships)})
    end
  end

  def switch_organization(_conn, _params), do: {:error, :unprocessable_entity}

  # The `me` payload shape used both here (sign-in, switch) and by MeController.
  defp render_me(user, current_member, memberships) do
    %{
      user: user_json(user),
      current_member: member_json(current_member),
      memberships: Enum.map(memberships, &member_json/1),
      organization: organization_json(current_member && current_member.organization)
    }
  end

  defp user_json(user) do
    %{
      id: user.id,
      primary_email: user.primary_email,
      primary_email_verified: user.primary_email_verified,
      display_name: user.display_name,
      avatar_url: user.avatar_url,
      locale: user.locale,
      status: user.status,
      inserted_at: user.inserted_at,
      last_login_at: user.last_login_at
    }
  end

  defp member_json(nil), do: nil

  defp member_json(member) do
    %{
      id: member.id,
      organization_id: member.organization_id,
      user_id: member.user_id,
      email: member.email,
      display_name: member.display_name,
      role: member.role,
      status: member.status,
      joined_at: member.joined_at,
      last_active_at: member.last_active_at,
      organization: organization_json(Map.get(member, :organization))
    }
  end

  defp organization_json(nil), do: nil
  defp organization_json(%Ecto.Association.NotLoaded{}), do: nil

  defp organization_json(org) do
    %{
      id: org.id,
      name: org.name,
      slug: org.slug,
      status: org.status,
      inserted_at: org.inserted_at
    }
  end
end
