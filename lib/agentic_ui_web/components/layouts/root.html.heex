<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="AgenticUi">
      {assigns[:page_title]}
    </.live_title>
    <%= if vite_config = Application.get_env(:agentic_ui, :vite_dev_server) do %>
      <script type="module" src={"//#{@request_host}:#{vite_config[:port]}/@vite/client"}>
      </script>
      <script type="module" src={"//#{@request_host}:#{vite_config[:port]}/src/main.ts"}>
      </script>
    <% else %>
      <link phx-track-static rel="stylesheet" href={~p"/assets/main.css"} />
      <script defer phx-track-static type="module" src={~p"/assets/main.js"}>
      </script>
    <% end %>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
